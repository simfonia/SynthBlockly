<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="v_note">note</variable>
  </variables>

  <!-- 初始化區塊：放置於最頂端，確保優先執行 -->
  <block type="sb_comment" id="init_header" x="10" y="10">
    <field name="COMMENT">【初始化設定】&amp;#10;這裡定義全曲共用的和弦與設定，確保在演奏開始前就緒。</field>
    <next>
      <block type="sb_transport_set_bpm" id="set_bpm">
        <field name="BPM">120</field>
        <next>
          <!-- 預先定義和弦 (全域有效) -->
          <block type="sb_define_chord" id="setup_chord_f">
            <field name="NAME">F</field>
            <field name="NOTES_STRING">F4,A4,C5</field>
            <next>
              <block type="sb_define_chord" id="setup_chord_g">
                <field name="NAME">G</field>
                <field name="NOTES_STRING">G4,B4,D5</field>
                <next>
                  <!-- 主程式結構 -->
                  <block type="sb_comment" id="flow_start">
                    <field name="COMMENT">【主程式】安排段落結構</field>
                    <next>
                      <block type="procedures_callnoreturn" id="call_v1">
                        <mutation name="演奏主歌"></mutation>
                        <next>
                          <block type="procedures_callnoreturn" id="call_c1">
                            <mutation name="演奏副歌"></mutation>
                            <next>
                              <block type="procedures_callnoreturn" id="call_v2">
                                <mutation name="演奏主歌"></mutation>
                                <next>
                                  <block type="procedures_callnoreturn" id="call_c2">
                                    <mutation name="演奏副歌"></mutation>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>

  <!-- 函式定義：主歌 (Verse) -->
  <block type="procedures_defnoreturn" id="def_verse" x="450" y="10">
    <field name="NAME">演奏主歌</field>
    <statement name="STACK">
      <block type="sb_play_note_and_wait" id="v1">
        <field name="DUR">4n</field>
        <value name="NOTE"><shadow type="text"><field name="TEXT">C4</field></shadow></value>
        <value name="VELOCITY"><shadow type="math_number"><field name="NUM">0.8</field></shadow></value>
        <next>
          <block type="sb_play_note_and_wait" id="v2">
            <field name="DUR">4n</field>
            <value name="NOTE"><shadow type="text"><field name="TEXT">E4</field></shadow></value>
            <value name="VELOCITY"><shadow type="math_number"><field name="NUM">0.8</field></shadow></value>
            <next>
              <block type="sb_play_note_and_wait" id="v3">
                <field name="DUR">4n</field>
                <value name="NOTE"><shadow type="text"><field name="TEXT">G4</field></shadow></value>
                <value name="VELOCITY"><shadow type="math_number"><field name="NUM">0.8</field></shadow></value>
                <next>
                  <block type="sb_play_note_and_wait" id="v4">
                    <field name="DUR">4n</field>
                    <value name="NOTE"><shadow type="text"><field name="TEXT">C5</field></shadow></value>
                    <value name="VELOCITY"><shadow type="math_number"><field name="NUM">0.8</field></shadow></value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- 函式定義：副歌 (Chorus) -->
  <block type="procedures_defnoreturn" id="def_chorus" x="450" y="250">
    <field name="NAME">演奏副歌</field>
    <statement name="STACK">
      <block type="sb_play_chord_by_name" id="c1">
        <field name="CHORD_NAME">F</field>
        <field name="DUR">2n</field>
        <value name="VELOCITY"><shadow type="math_number"><field name="NUM">1</field></shadow></value>
        <next>
          <block type="sb_wait_musical" id="wait1">
            <field name="DURATION">2n</field>
            <next>
              <block type="sb_play_chord_by_name" id="c2">
                <field name="CHORD_NAME">G</field>
                <field name="DUR">2n</field>
                <value name="VELOCITY"><shadow type="math_number"><field name="NUM">1</field></shadow></value>
                <next>
                  <block type="sb_wait_musical" id="wait2">
                    <field name="DURATION">2n</field>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>